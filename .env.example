MYSQL_USER=not-a-real-user
MYSQL_PASSWORD=not-a-real-password

## app
MYSQL_HOST=not-a-real-host
REDIS_HOST=not-a-real-host
NEXTCLOUD_ADMIN_USER=not-a-real-user
